share_top_decile <- top_decile_stops / sum(officer_year$stops)
cat(sprintf(
"\nConcentration: the top 10%% of officers (n = %s) account for %s of all stops.\n",
fmt_int(top_decile_n), fmt_pct(share_top_decile)
))
cat("\n", strrep("=", 70), "\n", sep = "")
cat("End of narrative.\n")
