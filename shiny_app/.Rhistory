for (i in seq_len(nrow(top_partners))) {
r <- top_partners[i, ]
cat(sprintf("  %s: %s partners, %s stops\n",
r$OFFICER_ID, fmt_int(r$partners), fmt_int(r$stops)))
}
# Concentration: what share of stops do the top 10% of officers account for?
n_off <- nrow(officer_year)
top_decile_n <- max(1, ceiling(n_off * 0.10))
top_decile_stops <- officer_year %>%
arrange(desc(stops)) %>%
slice_head(n = top_decile_n) %>%
summarise(s = sum(stops)) %>% pull(s)
share_top_decile <- top_decile_stops / sum(officer_year$stops)
cat(sprintf(
"\nConcentration: the top 10%% of officers (n = %s) account for %s of all stops.\n",
fmt_int(top_decile_n), fmt_pct(share_top_decile)
))
cat("\n", strrep("=", 70), "\n", sep = "")
cat("End of narrative.\n")
# narrative.R
# Generates an overall narrative of the CPD Unit 189 (Narcotics) 2016 data
# shown in the Shiny visualization. Run after sourcing the same data file.
#
# Outputs a printed summary to the console covering:
#   - Year-level totals
#   - Month-by-month activity
#   - Peaks and valleys (which months stood out, and how)
#   - Network-level shape (partnerships, hub officers)
library(dplyr)
library(lubridate)
library(scales)
# ---- Data ----
data <- readRDS("data.rds")
NODES           <- data$NODES
EDGE_CONTRIBS   <- data$EDGE_CONTRIBS
SCOPE_FOR_SHINY <- data$SCOPE_FOR_SHINY
EDGE_DURATION_DAYS <- 14
EDGE_DURATION_SEC  <- EDGE_DURATION_DAYS * 86400
# ---- Helpers ----
fmt_int <- function(x) format(round(x), big.mark = ",")
fmt_pct <- function(x) if (is.na(x)) "—" else percent(x, accuracy = 0.1)
month_name <- function(d) format(d, "%B")
section <- function(title) {
cat("\n", strrep("=", 70), "\n", sep = "")
cat(title, "\n")
cat(strrep("=", 70), "\n", sep = "")
}
# ---- Build per-month summaries ----
scope_monthly <- SCOPE_FOR_SHINY %>%
mutate(month = floor_date(CONTACT_DATE, "month")) %>%
group_by(month) %>%
summarise(
stops          = n(),
searches       = sum(SEARCHED, na.rm = TRUE),
hits           = sum(HIT, na.rm = TRUE),
active_officers = n_distinct(OFFICER_ID),
.groups = "drop"
) %>%
mutate(
hit_rate    = ifelse(searches > 0, hits / searches, NA_real_),
search_rate = ifelse(stops > 0, searches / stops, NA_real_),
stops_per_officer = stops / active_officers
)
# Active partnerships per month: count distinct (FROM, TO) pairs whose
# 14-day active window overlaps any part of the month.
month_starts <- seq(
floor_date(min(SCOPE_FOR_SHINY$CONTACT_DATE), "month"),
floor_date(max(SCOPE_FOR_SHINY$CONTACT_DATE), "month"),
by = "month"
)
month_ends <- ceiling_date(month_starts, "month") - 1
partnerships_monthly <- integer(length(month_starts))
for (i in seq_along(month_starts)) {
ms <- month_starts[i]
me <- month_ends[i]
partnerships_monthly[i] <- EDGE_CONTRIBS %>%
mutate(active_to = EVENT_TIME + EDGE_DURATION_SEC) %>%
filter(EVENT_TIME <= me, active_to >= ms) %>%
distinct(FROM, TO) %>%
nrow()
}
partnerships_df <- data.frame(
month         = month_starts,
partnerships  = partnerships_monthly
)
monthly <- scope_monthly %>% left_join(partnerships_df, by = "month")
# ---- Year-level overview ----
total_stops    <- sum(monthly$stops)
total_searches <- sum(monthly$searches)
total_hits     <- sum(monthly$hits)
year_hit_rate  <- total_hits / total_searches
year_search_rate <- total_searches / total_stops
n_officers_year <- n_distinct(SCOPE_FOR_SHINY$OFFICER_ID)
n_partnerships_year <- EDGE_CONTRIBS %>% distinct(FROM, TO) %>% nrow()
section("OVERVIEW — CPD UNIT 189 (NARCOTICS), 2016")
cat(sprintf("Officers active during the year: %s\n", fmt_int(n_officers_year)))
cat(sprintf("Total stops:                     %s\n", fmt_int(total_stops)))
cat(sprintf("Total searches:                  %s (%s of stops)\n",
fmt_int(total_searches), fmt_pct(year_search_rate)))
cat(sprintf("Total hits:                      %s (%s hit rate)\n",
fmt_int(total_hits), fmt_pct(year_hit_rate)))
cat(sprintf("Distinct co-event partnerships:  %s\n", fmt_int(n_partnerships_year)))
# ---- Month-by-month walk ----
section("MONTH BY MONTH")
cat(sprintf("%-10s %8s %9s %8s %9s %11s %12s\n",
"Month", "Stops", "Searches", "Hits",
"Hit rate", "Srch rate", "Partnerships"))
cat(strrep("-", 70), "\n", sep = "")
for (i in seq_len(nrow(monthly))) {
r <- monthly[i, ]
cat(sprintf("%-10s %8s %9s %8s %9s %11s %12s\n",
format(r$month, "%b"),
fmt_int(r$stops),
fmt_int(r$searches),
fmt_int(r$hits),
fmt_pct(r$hit_rate),
fmt_pct(r$search_rate),
fmt_int(r$partnerships)))
}
# ---- Peaks and valleys ----
section("PEAKS AND VALLEYS")
peak_stops <- monthly %>% slice_max(stops, n = 1)
low_stops  <- monthly %>% slice_min(stops, n = 1)
cat(sprintf(
"Activity peak:   %s (%s stops, %s searches)\n",
month_name(peak_stops$month), fmt_int(peak_stops$stops), fmt_int(peak_stops$searches)
))
cat(sprintf(
"Activity valley: %s (%s stops, %s searches)\n",
month_name(low_stops$month), fmt_int(low_stops$stops), fmt_int(low_stops$searches)
))
stops_ratio <- peak_stops$stops / low_stops$stops
cat(sprintf(
"  -> %s had ~%.1fx the stops of %s.\n",
month_name(peak_stops$month), stops_ratio, month_name(low_stops$month)
))
# Hit rate peaks/valleys (only consider months with enough searches to be stable)
hr_eligible <- monthly %>% filter(searches >= 50)
if (nrow(hr_eligible) > 0) {
hr_peak <- hr_eligible %>% slice_max(hit_rate, n = 1)
hr_low  <- hr_eligible %>% slice_min(hit_rate, n = 1)
cat(sprintf(
"\nHighest hit rate: %s at %s (%s searches).\n",
month_name(hr_peak$month), fmt_pct(hr_peak$hit_rate), fmt_int(hr_peak$searches)
))
cat(sprintf(
"Lowest hit rate:  %s at %s (%s searches).\n",
month_name(hr_low$month), fmt_pct(hr_low$hit_rate), fmt_int(hr_low$searches)
))
}
# Search rate peaks/valleys
sr_peak <- monthly %>% slice_max(search_rate, n = 1)
sr_low  <- monthly %>% slice_min(search_rate, n = 1)
cat(sprintf(
"\nMost aggressive search behavior: %s (search rate %s).\n",
month_name(sr_peak$month), fmt_pct(sr_peak$search_rate)
))
cat(sprintf(
"Least aggressive search behavior: %s (search rate %s).\n",
month_name(sr_low$month), fmt_pct(sr_low$search_rate)
))
# Partnership peaks/valleys
pp_peak <- monthly %>% slice_max(partnerships, n = 1)
pp_low  <- monthly %>% slice_min(partnerships, n = 1)
cat(sprintf(
"\nDensest partnership network: %s (%s active partnerships).\n",
month_name(pp_peak$month), fmt_int(pp_peak$partnerships)
))
cat(sprintf(
"Sparsest partnership network: %s (%s active partnerships).\n",
month_name(pp_low$month), fmt_int(pp_low$partnerships)
))
# ---- Trend across the year ----
section("TREND ACROSS THE YEAR")
first_half <- monthly %>% filter(month(month) <= 6)
second_half <- monthly %>% filter(month(month) >= 7)
fh_stops <- sum(first_half$stops); sh_stops <- sum(second_half$stops)
fh_hr <- sum(first_half$hits) / sum(first_half$searches)
sh_hr <- sum(second_half$hits) / sum(second_half$searches)
cat(sprintf("First half (Jan–Jun):  %s stops, hit rate %s\n",
fmt_int(fh_stops), fmt_pct(fh_hr)))
cat(sprintf("Second half (Jul–Dec): %s stops, hit rate %s\n",
fmt_int(sh_stops), fmt_pct(sh_hr)))
direction <- if (sh_stops > fh_stops) "increased" else "decreased"
pct_change <- abs(sh_stops - fh_stops) / fh_stops
cat(sprintf("  -> Stop volume %s by %s in the second half.\n",
direction, fmt_pct(pct_change)))
# ---- Network shape ----
section("NETWORK SHAPE (FULL YEAR)")
# Officer-level counts across the whole year
officer_year <- SCOPE_FOR_SHINY %>%
group_by(OFFICER_ID) %>%
summarise(
stops    = n(),
searches = sum(SEARCHED, na.rm = TRUE),
hits     = sum(HIT, na.rm = TRUE),
.groups  = "drop"
)
# Partner counts: how many distinct co-event partners each officer had
partners_year <- bind_rows(
EDGE_CONTRIBS %>% select(OFFICER_ID = FROM, partner = TO),
EDGE_CONTRIBS %>% select(OFFICER_ID = TO,   partner = FROM)
) %>%
distinct(OFFICER_ID, partner) %>%
count(OFFICER_ID, name = "partners")
officer_year <- officer_year %>%
left_join(partners_year, by = "OFFICER_ID") %>%
mutate(partners = ifelse(is.na(partners), 0L, partners))
med_stops    <- median(officer_year$stops)
med_partners <- median(officer_year$partners)
top_stops    <- officer_year %>% slice_max(stops,    n = 3)
top_partners <- officer_year %>% slice_max(partners, n = 3)
cat(sprintf("Median stops per officer:    %s\n",   fmt_int(med_stops)))
cat(sprintf("Median partners per officer: %s\n\n", fmt_int(med_partners)))
cat("Most active officers (by stops):\n")
for (i in seq_len(nrow(top_stops))) {
r <- top_stops[i, ]
cat(sprintf("  %s: %s stops, %s partners\n",
r$OFFICER_ID, fmt_int(r$stops), fmt_int(r$partners)))
}
cat("\nMost connected officers (by partner count):\n")
for (i in seq_len(nrow(top_partners))) {
r <- top_partners[i, ]
cat(sprintf("  %s: %s partners, %s stops\n",
r$OFFICER_ID, fmt_int(r$partners), fmt_int(r$stops)))
}
# Concentration: what share of stops do the top 10% of officers account for?
n_off <- nrow(officer_year)
top_decile_n <- max(1, ceiling(n_off * 0.10))
top_decile_stops <- officer_year %>%
arrange(desc(stops)) %>%
slice_head(n = top_decile_n) %>%
summarise(s = sum(stops)) %>% pull(s)
share_top_decile <- top_decile_stops / sum(officer_year$stops)
cat(sprintf(
"\nConcentration: the top 10%% of officers (n = %s) account for %s of all stops.\n",
fmt_int(top_decile_n), fmt_pct(share_top_decile)
))
cat("\n", strrep("=", 70), "\n", sep = "")
cat("End of narrative.\n")
# diagnose.R — figure out why January partnerships shows 0 in narrative
# but 42 in the app
library(dplyr)
library(lubridate)
data <- readRDS("data.rds")
EDGE_CONTRIBS <- data$EDGE_CONTRIBS
EDGE_DURATION_SEC <- 14 * 86400
cat("=== EDGE_CONTRIBS structure ===\n")
str(EDGE_CONTRIBS)
cat("\n=== EVENT_TIME class & timezone ===\n")
cat("class:", class(EDGE_CONTRIBS$EVENT_TIME), "\n")
cat("tzone:", attr(EDGE_CONTRIBS$EVENT_TIME, "tzone"), "\n")
cat("\n=== EVENT_TIME range ===\n")
cat("min:", format(min(EDGE_CONTRIBS$EVENT_TIME)), "\n")
cat("max:", format(max(EDGE_CONTRIBS$EVENT_TIME)), "\n")
cat("\n=== Events in January 2016 (UTC) ===\n")
jan_start <- as.POSIXct("2016-01-01", tz = "UTC")
jan_end   <- as.POSIXct("2016-01-31 23:59:59", tz = "UTC")
in_jan <- EDGE_CONTRIBS %>%
filter(EVENT_TIME >= jan_start, EVENT_TIME <= jan_end)
cat("Records with EVENT_TIME in Jan:", nrow(in_jan), "\n")
cat("Distinct (FROM, TO) pairs in Jan:", in_jan %>% distinct(FROM, TO) %>% nrow(), "\n")
cat("\n=== Replicating the APP's exact January filter ===\n")
ws <- as.POSIXct("2016-01-01", tz = "UTC")
we <- as.POSIXct("2016-01-31", tz = "UTC")  # what the slider would send for max=Dec 31, brushed to Jan 31
app_result <- EDGE_CONTRIBS %>%
filter(EVENT_TIME >= ws - EDGE_DURATION_SEC, EVENT_TIME <= we) %>%
mutate(EDGE_ACTIVE_FROM = EVENT_TIME,
EDGE_ACTIVE_TO   = EVENT_TIME + EDGE_DURATION_SEC) %>%
filter(EDGE_ACTIVE_TO >= ws, EDGE_ACTIVE_FROM <= we) %>%
group_by(FROM, TO) %>%
summarise(N_EVENTS = n(), .groups = "drop")
cat("App-style result for Jan 1-31:", nrow(app_result), "partnerships\n")
cat("\n=== Replicating the NARRATIVE's January filter ===\n")
ms <- as.POSIXct("2016-01-01", tz = "UTC")
me <- ceiling_date(ms, "month") - 1  # this is what narrative.R computes
cat("ms:", format(ms), " me:", format(me), "\n")
narr_result <- EDGE_CONTRIBS %>%
mutate(active_to = EVENT_TIME + EDGE_DURATION_SEC) %>%
filter(EVENT_TIME <= me, active_to >= ms) %>%
distinct(FROM, TO) %>%
nrow()
cat("Narrative-style result for Jan:", narr_result, "partnerships\n")
cat("\n=== First 5 January events, with computed active windows ===\n")
EDGE_CONTRIBS %>%
filter(EVENT_TIME >= jan_start, EVENT_TIME <= jan_end) %>%
mutate(active_to = EVENT_TIME + EDGE_DURATION_SEC) %>%
arrange(EVENT_TIME) %>%
head(5) %>%
print()
source("~/Course_Work/INLS_541/FINAL_PROJECT/narrative.R", echo = TRUE)
